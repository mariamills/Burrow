# Burrow Environment Configuration
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.

# REQUIRED:

# Master encryption key: used to derive AES-256-GCM keys
# Generate with: openssl rand -base64 48
# Minimum 32 characters. Changing this requires re-encrypting all secrets.
BURROW_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_base64_48

# Root administrator token — full access to all namespaces.
# Generate with: openssl rand -base64 32
# Store this somewhere safe — it's the only token that cannot be revoked.
BURROW_ROOT_TOKEN=CHANGE_ME_generate_with_openssl_rand_base64_32

# OPTIONAL:

BURROW_PORT=8080
BURROW_HOST=127.0.0.1            # default: localhost only. Set 0.0.0.0 to expose on network.
BURROW_ENV=development           # "development" | "production"
BURROW_DB_PATH=./burrow.db       # SQLite database file path
BURROW_RATE_LIMIT=60             # requests per minute per IP
BURROW_AUDIT_ENABLED=true        # write audit log to DB
BURROW_LOG_LEVEL=info            # debug | info | warn | error
BURROW_ALLOWED_ORIGINS=          # CORS origins (comma-separated, or "*"). Empty = disabled.
BURROW_TRUST_PROXY=false         # trust X-Forwarded-For (set true behind Nginx/Traefik)

# TLS (required in production):
# BURROW_TLS_CERT=/path/to/cert.pem
# BURROW_TLS_KEY=/path/to/key.pem
